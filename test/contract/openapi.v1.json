  "components": {
    "schemas": {
      "AuthStatusResponse": {
        "required": [
          "status"
        ],
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          }
        }
      },
      "AuthTokens": {
        "required": [
          "accessToken",
          "refreshToken",
          "tokenType",
          "expiresInSeconds",
          "userId"
        ],
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string"
          },
          "refreshToken": {
            "type": "string"
          },
          "tokenType": {
            "type": "string"
          },
          "expiresInSeconds": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "userId": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "ForgotPasswordRequest": {
        "required": [
          "email"
        ],
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          }
        }
      },
      "GuestSignInRequest": {
        "required": [
          "locale",
          "deviceId"
        ],
        "type": "object",
        "properties": {
          "locale": {
            "type": [
              "null",
              "string"
            ]
          },
          "deviceId": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "LinkAccountRequest": {
        "required": [
          "email",
          "password"
        ],
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        }
      },
      "LoginRequest": {
        "required": [
          "email",
          "password",
          "deviceId"
        ],
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "password": {
            "type": "string"
          },
          "deviceId": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "LogoutRequest": {
        "required": [
          "refreshToken",
          "allDevices"
        ],
        "type": "object",
        "properties": {
          "refreshToken": {
            "type": "string"
          },
          "allDevices": {
            "type": "boolean"
          }
        }
      },
      "PlayerProfile": {
        "required": [
          "id",
          "displayName",
          "locale",
          "status",
          "createdAtUtc"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "displayName": {
            "type": "string"
          },
          "locale": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "createdAtUtc": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ProblemDetails": {
        "type": "object",
        "properties": {
          "type": {
            "type": [
              "null",
              "string"
            ]
          },
          "title": {
            "type": [
              "null",
              "string"
            ]
          },
          "status": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "detail": {
            "type": [
              "null",
              "string"
            ]
          },
          "instance": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "RefreshRequest": {
        "required": [
          "refreshToken",
          "deviceId"
        ],
        "type": "object",
        "properties": {
          "refreshToken": {
            "type": "string"
          },
          "deviceId": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "RegisterRequest": {
        "required": [
          "email",
          "password",
          "displayName",
          "locale"
        ],
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "password": {
            "type": "string"
          },
          "displayName": {
            "type": [
              "null",
              "string"
            ]
          },
          "locale": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "ResetPasswordRequest": {
        "required": [
          "email",
          "token",
          "newPassword"
        ],
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "token": {
            "type": "string"
